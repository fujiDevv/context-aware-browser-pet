{
  "name": "browser-pet-extension",
  "version": "1.1.0",
  "dependencies": {
    "@huggingface/transformers": "^4.2.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.7.1",
    "@playwright/test": "^1.61.1",
    "@types/chrome": "^0.2.2",
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "description": "Context-aware browser pet extension using arcrawls-pet SVGs.",
  "scripts": {
    "type-check": "node node_modules/typescript/bin/tsc --noEmit",
    "test": "vitest __tests__",
    "test:unit": "vitest run __tests__",
    "test:e2e": "playwright test",
    "dev": "vite build --watch",
    "build": "vite build",
    "build:firefox": "vite build && node build-firefox.mjs",
    "verify": "bun run type-check && bun run test:unit && bun run test:e2e",
    "all": "bun run build && bun run verify && bun run build:firefox"
  },
  "type": "module"
}
