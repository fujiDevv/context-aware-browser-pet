{
  "manifest_version": 3,
  "name": "Clawd: The Context-Aware Browser Pet",
  "version": "1.0.0",
  "description": "An interactive, context-aware browser mascot pet companion.",
  "permissions": [
    "storage",
    "tabs",
    "webNavigation",
    "webRequest",
    "offscreen"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/pet16.png",
      "48": "assets/pet48.png",
      "128": "assets/pet128.png"
    }
  },
  "icons": {
    "16": "assets/pet16.png",
    "48": "assets/pet48.png",
    "128": "assets/pet128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*",
        "onboarding/*",
        "wasm/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; connect-src 'self' https://huggingface.co https://*.huggingface.co https://*.hf.co https://*.xethub.hf.co"
  }
}