{
  "manifest_version": 3,
  "name": "Browser Pet",
  "version": "1.0.0",
  "description": "A context-aware clawd-pet that crawls your browser.",
  "permissions": [
    "storage",
    "tabs",
    "webNavigation",
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "main_world.js"
      ],
      "world": "MAIN",
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/pet16.png",
      "48": "assets/pet48.png",
      "128": "assets/pet128.png"
    }
  },
  "icons": {
    "16": "assets/pet16.png",
    "48": "assets/pet48.png",
    "128": "assets/pet128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}